#!/usr/bin/env node
// @ts-check
/// <reference types="node" />

const url = process.argv[2];

if (!url) {
  console.error('Usage: agent-fetch <url>');
  process.exit(1);
}

try {
  new URL(url);
} catch (error) {
  console.error('Invalid URL: ' + url);
  process.exit(1);
}

async function main() {
  console.log('Fetching ' + url);
}

main()
  .then(() => {
    process.exit(0);
  })
  .catch((error) => {
    console.error(error);
    process.exit(1);
  });
