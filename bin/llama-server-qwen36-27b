#!/bin/sh

set -eu

HOST="${PI_LLAMA_CPP_HOST:-127.0.0.1}"
PORT="${PI_LLAMA_CPP_PORT:-8012}"

# https://unsloth.ai/docs/models/qwen3.6#qwen3.6-27b
exec /Users/alisnic/OSS/llama-cpp-turboquant/build/bin/llama-server \
  -hf "unsloth/Qwen3.6-27B-GGUF:UD-Q4_K_XL" \
  --host "$HOST" \
  --port "$PORT" \
  --flash-attn on \
  --parallel 1 \
  --n-gpu-layers all \
  --ctx-size 64000 \
  --cache-type-k q8_0 \
  --cache-type-v turbo4 \
  --temp 0.6 \
  --top-p 0.95 \
  --top-k 20 \
  --min-p 0.0 \
  --presence-penalty 0.0
# --repeat-penalty 1.0
