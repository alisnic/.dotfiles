#!/usr/bin/env node

import { spawn } from 'node:child_process';
import { closeSync, existsSync, fstatSync, openSync, realpathSync, statSync, writeSync } from 'node:fs';
import { homedir } from 'node:os';
import { join } from 'node:path';
import process from 'node:process';
import { fileURLToPath } from 'node:url';

const separatorIndex = process.argv.indexOf('--');
const sandboxArgs = separatorIndex === -1 ? process.argv.slice(2) : process.argv.slice(2, separatorIndex);
const commandArgs = separatorIndex === -1 ? [] : process.argv.slice(separatorIndex + 1);

const usage = 'Usage: mysandbox [--rw path1,path2,pathN] -- <command> [args...]';

if (commandArgs.length === 0) {
  console.error(usage);
  process.exit(2);
}

const escapeSbplString = value => value.replace(/\\/g, '\\\\').replace(/"/g, '\\"');
const protectedSandboxScript = realpathSync(fileURLToPath(import.meta.url));
const protectedSandboxScriptStat = statSync(protectedSandboxScript);
const sshDirectory = join(homedir(), '.ssh');
const protectedSshDirectory = existsSync(sshDirectory) ? realpathSync(sshDirectory) : sshDirectory;

const expandHome = path => {
  if (path === '~') {
    return homedir();
  }

  if (path.startsWith('~/')) {
    return join(homedir(), path.slice(2));
  }

  return path;
};

const isSameFile = (left, right) => left.dev === right.dev && left.ino === right.ino;

const isFdTargetingProtectedSandboxScript = fd => {
  try {
    return isSameFile(fstatSync(fd), protectedSandboxScriptStat);
  } catch {
    return false;
  }
};

const writeDiagnostic = message => {
  if (!isFdTargetingProtectedSandboxScript(2)) {
    console.error(message);
    return;
  }

  try {
    const tty = openSync('/dev/tty', 'w');

    try {
      writeSync(tty, `${message}\n`);
    } finally {
      closeSync(tty);
    }
  } catch {
    // Avoid writing diagnostics into the protected script if stderr is unsafe.
  }
};

if (isFdTargetingProtectedSandboxScript(1) || isFdTargetingProtectedSandboxScript(2)) {
  writeDiagnostic('Refusing to run: mysandbox output is redirected to the wrapper itself');
  process.exit(1);
}

const writablePaths = [];

for (let index = 0; index < sandboxArgs.length; index += 1) {
  const arg = sandboxArgs[index];

  if (arg !== '--rw') {
    console.error(`Unknown option: ${arg}`);
    console.error(usage);
    process.exit(2);
  }

  const value = sandboxArgs[index + 1];

  if (!value) {
    console.error('--rw expects a comma-separated list of folders');
    console.error(usage);
    process.exit(2);
  }

  writablePaths.push(...value.split(',').filter(Boolean));
  index += 1;
}

const writablePathRules = writablePaths
  .map(path => {
    try {
      return realpathSync(expandHome(path));
    } catch (error) {
      console.error(`Invalid --rw path: ${path}`);
      console.error(error.message);
      process.exit(2);
    }
  })
  .map(path => `(allow file-write*\n  (subpath "${escapeSbplString(path)}"))`)
  .join('\n\n');

const profile = `
(version 1)

;; Deny filesystem writes globally, then grant them back only for --rw paths.
(deny file-write*)

(allow default)

;; Many CLIs redirect noisy output to /dev/null; allow that without granting
;; general filesystem writes.
(allow file-write*
  (literal "/dev/null"))

${writablePathRules}

;; Prevent child processes from modifying this wrapper, even when its parent
;; directory is included in --rw.
(deny file-write*
  (literal "${escapeSbplString(protectedSandboxScript)}"))

;; Never expose SSH credentials, even when ~/.ssh is included in --rw.
(deny file-read* file-write*
  (subpath "${escapeSbplString(protectedSshDirectory)}"))
`;

const child = spawn('sandbox-exec', ['-p', profile, ...commandArgs], {
  stdio: 'inherit'
});

child.on('error', error => {
  console.error(`Failed to launch sandbox-exec: ${error.message}`);
  process.exit(1);
});

child.on('exit', (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
    return;
  }

  process.exit(code ?? 1);
});
